# Default in server.js is 5100 if unset
PORT=5100
# Local or Atlas, e.g. mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/DB?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/gaas

# Google OAuth Web client (same as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# JWT signing secret for /api/auth/google-login
JWT_SECRET=change-me-in-production

# Only this email can call GET /api/admin/users
ADMIN_EMAIL=saisathwik123456@gmail.com

MQTT_BROKER_URL=mqtt://localhost:1883
AI_SERVICE_URL=http://localhost:8000

# Where Express proxies /api/yield/* (yield prediction). Default Flask crop_api / app.py.
# FLASK_ML_URL=http://127.0.0.1:5000

# Razorpay payment gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
