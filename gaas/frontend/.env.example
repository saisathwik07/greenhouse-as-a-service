# Dev: omit VITE_API_BASE_URL — Vite proxies /api (auth/admin → Node, rest → Flask).
# Vite dev server port (default 5173). Must match Google Cloud "Authorized JavaScript origins".
# VITE_DEV_PORT=5173
# Must match where Express listens (backend PORT, default 5100):
# VITE_DEV_NODE_URL=http://127.0.0.1:5100
# VITE_DEV_FLASK_URL=http://127.0.0.1:5000
# Flask for crop_api + yield (default 5000). Vite /yield-api proxy uses this too.
# VITE_YIELD_API_URL=http://127.0.0.1:5000
# Optional: override where the browser calls yield /crops and /predict (dev defaults to http://127.0.0.1:5000):
# VITE_YIELD_ORIGIN=http://127.0.0.1:5000
# Preferred unified API base for frontend (src/config.js + src/api.js).
# Accepts either a bare origin (Vercel/prod) OR "/api" (Vite proxy in dev).
#   Dev:  VITE_API_URL=/api
#   Prod: VITE_API_URL=https://greenhouse-as-a-service.onrender.com
# VITE_API_URL=/api
# VITE_API_URL=https://greenhouse-as-a-service.onrender.com

# Legacy alias (kept for backward compat with old code paths)
# VITE_API_BASE_URL=http://localhost:5100/api
# Razorpay publishable key for checkout
# VITE_RAZORPAY_KEY_ID=
# Greenhouse IoT sim API (Flask-SocketIO). See gaas/iot-sim-api/app.py — default port 5050.
# VITE_IOT_SIM_URL=http://localhost:5050

# Google Sign-In (@react-oauth/google). Use an OAuth client type "Web application".
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
#
# If Google shows Error 400: origin_mismatch — add Authorized JavaScript origins for THIS client:
#   Google Cloud Console → APIs & Services → Credentials → [your Web client] →
#   "Authorized JavaScript origins" → Add URI → exactly:
#     http://localhost:5173
#   (If you use http://127.0.0.1:5173 in the browser, add that as a second origin — it is different.)
#   Save, wait a minute, hard-refresh (Ctrl+Shift+R). Must match Vite port (see VITE_DEV_PORT above).

# Must match backend ADMIN_EMAIL (default: saisathwik123456@gmail.com)
# VITE_ADMIN_EMAIL=saisathwik123456@gmail.com
